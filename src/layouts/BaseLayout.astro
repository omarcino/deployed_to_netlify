---
import '../styles/global.css';
import tileBg from '../assets/images/tile.jpg';

interface Props {
  title: string;
}

const { title } = Astro.props;

const pathname = Astro.url.pathname;
function navClass(href: string) {
  const isActive = href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
  return isActive
    ? 'text-white bg-white/15 rounded-md px-3 py-1.5 text-sm font-medium transition-all'
    : 'text-gray-300 hover:text-white hover:bg-white/10 rounded-md px-3 py-1.5 text-sm transition-all';
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen" style={`background-image: url(${tileBg.src}); background-repeat: repeat;`}>
    <div class="max-w-4xl mx-auto min-h-screen flex flex-col">
      <header class="px-6 py-4 text-white" style="background-color: #3E4249;">
        <nav class="flex items-center justify-between">
          <a href="/" class="font-semibold text-lg">Omar Nina</a>

          <!-- Desktop links -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/blog" class={navClass('/blog')}>Blog</a>
            <a href="/quotes" class={navClass('/quotes')}>Quotes</a>
            <a href="/projects" class={navClass('/projects')}>Projects</a>
            <div class="flex items-center border rounded px-3 py-1 gap-2 text-gray-400">
              <input type="search" placeholder="Search..." class="outline-none text-sm bg-transparent text-white placeholder-gray-400 w-32" />
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
              </svg>
            </div>
          </div>

          <!-- Hamburger button -->
          <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5" aria-label="Toggle menu">
            <span class="block w-6 h-0.5 bg-white"></span>
            <span class="block w-6 h-0.5 bg-white"></span>
            <span class="block w-6 h-0.5 bg-white"></span>
          </button>
        </nav>

        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden flex-col gap-4 pt-4">
          <a href="/blog" class={navClass('/blog')}>Blog</a>
          <a href="/quotes" class={navClass('/quotes')}>Quotes</a>
          <a href="/projects" class={navClass('/projects')}>Projects</a>
          <div class="flex items-center border rounded px-3 py-1 gap-2 text-gray-400 w-fit">
            <input type="search" placeholder="Search..." class="outline-none text-sm bg-transparent text-white placeholder-gray-400 w-40" />
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
            </svg>
          </div>
        </div>
      </header>

      <script>
        const toggle = document.getElementById('menu-toggle');
        const menu = document.getElementById('mobile-menu');
        toggle?.addEventListener('click', () => {
          menu?.classList.toggle('hidden');
          menu?.classList.toggle('flex');
        });
      </script>
      <main class="flex-1 px-6 py-8 bg-white">
        <slot />
      </main>
      <footer class="px-6 py-4 text-sm text-white flex items-center justify-between" style="background-color: #3E4249;">
        <span>&copy; {new Date().getFullYear()}</span>
        <div class="flex items-center gap-4">
          <a href="https://github.com/omarcino?tab=repositories" target="_blank" rel="noopener" aria-label="GitHub">
            <svg class="h-5 w-5 fill-white hover:fill-gray-300" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.165c-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.3-5.467-1.332-5.467-5.93 0-1.31.468-2.381 1.236-3.221-.124-.303-.536-1.524.117-3.176 0 0 1.008-.322 3.3 1.23a11.52 11.52 0 0 1 3.003-.404c1.02.005 2.047.138 3.003.404 2.29-1.552 3.297-1.23 3.297-1.23.655 1.652.243 2.873.12 3.176.77.84 1.235 1.911 1.235 3.221 0 4.61-2.807 5.625-5.479 5.92.43.372.823 1.102.823 2.222v3.293c0 .322.218.694.825.576C20.565 21.796 24 17.298 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
          <a href="https://x.com/omarInfoTech" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg class="h-5 w-5 fill-white hover:fill-gray-300" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/omarnina/" target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg class="h-5 w-5 fill-white hover:fill-gray-300" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@omardata8317" target="_blank" rel="noopener" aria-label="YouTube">
            <svg class="h-5 w-5 fill-white hover:fill-gray-300" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </footer>
    </div>
  </body>
</html>
