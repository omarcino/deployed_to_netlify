---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const quotes = await getCollection('quotes');
  return quotes.map((quote) => ({
    params: { slug: quote.id },
    props: { quote },
  }));
}

const { quote } = Astro.props;
const { Content } = await render(quote);
---

<BaseLayout title={`"${quote.data.author}"`}>
  <article class="max-w-2xl mx-auto py-8">
    <blockquote class="border-l-4 border-gray-400 pl-6">
      <div class="text-2xl text-gray-800 italic leading-relaxed">
        <Content />
      </div>
      <footer class="mt-4 text-gray-600">
        — <span class="font-medium">{quote.data.author}</span>
        {quote.data.source && <span class="text-gray-400">, <em>{quote.data.source}</em></span>}
      </footer>
    </blockquote>
    <div class="mt-10">
      <a href="/quotes" class="text-sm text-gray-500 hover:text-gray-800">← All quotes</a>
    </div>
  </article>
</BaseLayout>
