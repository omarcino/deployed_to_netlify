---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const quotes = (await getCollection('quotes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Quotes">
  <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {quotes.map((quote) => (
      <li>
        <a href={`/quotes/${quote.id}`} class="block group h-full">
          <article class="bg-gray-50 hover:bg-gray-100 transition rounded-lg border border-gray-200 overflow-hidden h-full flex flex-col">
            {quote.data.image ? (
              <Image src={quote.data.image} alt={quote.data.author} width={800} height={400} class="w-full h-48 object-cover" />
            ) : (
              <div class="w-full h-48 bg-gray-200" />
            )}
            <div class="px-5 py-4 flex flex-col flex-1">
              <p class="text-gray-800 italic font-medium group-hover:underline">{quote.data.author}</p>
              {quote.data.source && <p class="text-sm text-gray-500 mt-1">{quote.data.source}</p>}
            </div>
          </article>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
