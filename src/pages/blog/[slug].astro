---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{post.data.title}</h1>
      <time class="text-sm text-gray-500">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>
    <div class="post-content text-gray-800 leading-relaxed">
      <Content />
    </div>
    <div class="mt-10">
      <a href="/blog" class="text-sm text-gray-500 hover:text-gray-800">← All posts</a>
    </div>
  </article>
</BaseLayout>

<style>
  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .post-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #111827;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .post-content :global(p) {
    margin-bottom: 1rem;
  }
  .post-content :global(hr) {
    border-color: #e5e7eb;
    margin: 2rem 0;
  }
  .post-content :global(em) {
    font-style: italic;
  }
  .post-content :global(strong) {
    font-weight: 700;
  }
  .post-content :global(code) {
    background: #f3f4f6;
    padding: 0.1em 0.3em;
    border-radius: 4px;
    font-size: 0.9em;
  }
  .post-content :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .post-content :global(ol) {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .post-content :global(li) {
    margin-bottom: 0.25rem;
  }
</style>
