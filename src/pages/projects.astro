---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Projects">
  <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((project) => (
      <li>
        <a href={`/projects/${project.id}`} class="block group h-full">
          <article class="bg-gray-50 hover:bg-gray-100 transition rounded-lg border border-gray-200 overflow-hidden h-full flex flex-col">
            {project.data.image ? (
              <img src={project.data.image} alt={project.data.title} class="w-full h-48 object-cover" />
            ) : (
              <div class="w-full h-48 bg-gray-200" />
            )}
            <div class="px-5 py-4 flex flex-col flex-1">
              <div class="flex items-start justify-between gap-2">
                <h2 class="text-lg font-semibold text-gray-900 group-hover:underline">{project.data.title}</h2>
                <time class="text-xs text-gray-500 shrink-0 mt-1">
                  {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                </time>
              </div>
              <p class="text-gray-600 mt-2">{project.data.description}</p>
              {project.data.tags && (
                <div class="flex gap-2 mt-3 flex-wrap">
                  {project.data.tags.map((tag) => (
                    <span class="text-xs bg-gray-200 text-gray-700 rounded px-2 py-0.5">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </article>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
