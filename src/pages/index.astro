---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const quotes = (await getCollection('quotes'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Omar Nina">
<div data-pagefind-ignore="all">
  <!-- Hero -->
  <section class="flex flex-col md:flex-row gap-8 items-start mb-16">
    <div class="shrink-0">
      <img
        src="/profile.jpg"
        alt="Omar Nina"
        class="w-36 h-36 rounded-full object-cover bg-gray-200"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
      <div class="w-36 h-36 rounded-full bg-gray-200 hidden items-center justify-center text-gray-400 text-4xl">
        &#128100;
      </div>
    </div>
    <div>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">Omar Nina</h1>
      <p class="text-gray-600 leading-relaxed mb-5">
        Data engineer and designer. I build data pipelines, design systems for complex processes, explore new tools, and write about what I learn along the way.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/omarcino?tab=repositories" target="_blank" rel="noopener" aria-label="GitHub">
          <svg class="h-5 w-5 fill-gray-600 hover:fill-gray-900 transition-colors" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.165c-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.085 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.605-2.665-.3-5.467-1.332-5.467-5.93 0-1.31.468-2.381 1.236-3.221-.124-.303-.536-1.524.117-3.176 0 0 1.008-.322 3.3 1.23a11.52 11.52 0 0 1 3.003-.404c1.02.005 2.047.138 3.003.404 2.29-1.552 3.297-1.23 3.297-1.23.655 1.652.243 2.873.12 3.176.77.84 1.235 1.911 1.235 3.221 0 4.61-2.807 5.625-5.479 5.92.43.372.823 1.102.823 2.222v3.293c0 .322.218.694.825.576C20.565 21.796 24 17.298 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
        <a href="https://x.com/omarInfoTech" target="_blank" rel="noopener" aria-label="X / Twitter">
          <svg class="h-5 w-5 fill-gray-600 hover:fill-gray-900 transition-colors" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/omarnina/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg class="h-5 w-5 fill-gray-600 hover:fill-gray-900 transition-colors" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://www.youtube.com/@omardata8317" target="_blank" rel="noopener" aria-label="YouTube">
          <svg class="h-5 w-5 fill-gray-600 hover:fill-gray-900 transition-colors" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Projects -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-gray-900">Latest Projects</h2>
      <a href="/projects" class="text-sm text-gray-500 hover:text-gray-800">View all →</a>
    </div>
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((project) => (
        <li>
          <a href={`/projects/${project.id}`} class="block group h-full">
            <article class="bg-gray-50 hover:bg-gray-100 transition rounded-lg border border-gray-200 overflow-hidden h-full flex flex-col">
              {project.data.image ? (
                <Image src={project.data.image} alt={project.data.title} width={800} height={400} class="w-full h-40 object-cover" />
              ) : (
                <div class="w-full h-40 bg-gray-200" />
              )}
              <div class="px-5 py-4 flex flex-col flex-1">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-semibold text-gray-900 group-hover:underline">{project.data.title}</h3>
                  <time class="text-xs text-gray-500 shrink-0 mt-0.5">
                    {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                  </time>
                </div>
                <p class="text-gray-600 mt-1">{project.data.description}</p>
                {project.data.tags && (
                  <div class="flex gap-2 mt-3 flex-wrap">
                    {project.data.tags.map((tag) => (
                      <span class="text-xs bg-gray-200 text-gray-700 rounded px-2 py-0.5">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Latest Posts -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-gray-900">Latest Posts</h2>
      <a href="/blog" class="text-sm text-gray-500 hover:text-gray-800">View all →</a>
    </div>
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}`} class="block group h-full">
            <article class="bg-gray-50 hover:bg-gray-100 transition rounded-lg border border-gray-200 overflow-hidden h-full flex flex-col">
              {post.data.image ? (
                <Image src={post.data.image} alt={post.data.title} width={800} height={400} class="w-full h-40 object-cover" />
              ) : (
                <div class="w-full h-40 bg-gray-200" />
              )}
              <div class="px-5 py-4 flex flex-col flex-1">
                <time class="text-xs text-gray-500">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h3 class="font-semibold text-gray-900 mt-1 group-hover:underline">{post.data.title}</h3>
                <p class="text-gray-600 mt-1">{post.data.description}</p>
              </div>
            </article>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- Latest Quotes -->
  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-gray-900">Latest Quotes</h2>
      <a href="/quotes" class="text-sm text-gray-500 hover:text-gray-800">View all →</a>
    </div>
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {quotes.map((quote) => (
        <li>
          <a href={`/quotes/${quote.id}`} class="block group h-full">
            <article class="bg-gray-50 hover:bg-gray-100 transition rounded-lg border border-gray-200 overflow-hidden h-full flex flex-col">
              {quote.data.image ? (
                <Image src={quote.data.image} alt={quote.data.author} width={800} height={400} class="w-full h-40 object-cover" />
              ) : (
                <div class="w-full h-40 bg-gray-200" />
              )}
              <div class="px-5 py-4 flex flex-col flex-1">
                <p class="text-gray-800 italic font-medium group-hover:underline">{quote.data.author}</p>
                {quote.data.source && <p class="text-sm text-gray-500 mt-1">{quote.data.source}</p>}
              </div>
            </article>
          </a>
        </li>
      ))}
    </ul>
  </section>
</div>
</BaseLayout>
