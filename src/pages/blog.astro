---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog">
  <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.id}`} class="block group h-full">
          <article class="bg-gray-50 hover:bg-gray-100 transition rounded-lg border border-gray-200 overflow-hidden h-full flex flex-col">
            {post.data.image ? (
              <img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover" />
            ) : (
              <div class="w-full h-48 bg-gray-200" />
            )}
            <div class="px-5 py-4 flex flex-col flex-1">
              <time class="text-xs text-gray-500">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="text-lg font-semibold text-gray-900 mt-1 group-hover:underline">{post.data.title}</h2>
              <p class="text-gray-600 mt-2">{post.data.description}</p>
            </div>
          </article>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
